---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BlogFolderCard from "@components/BlogFolderCard.astro";
import {
  type BlogEntry,
  type BlogFolderEntry,
  type BlogPostEntry,
  isBlogFolderEntry,
  isBlogPostEntry,
} from "@lib/blogEntries";
import { BLOG } from "@consts";

const entries = (await getCollection("blog")).filter(
  (post) => !post.data.draft,
);

const folderMetaBySlug = new Map<string, BlogFolderEntry>();
entries.forEach((entry) => {
  if (isBlogFolderEntry(entry)) {
    const folderSlug = entry.slug.replace(/\/index$/, "");
    if (folderSlug) {
      if (folderMetaBySlug.has(folderSlug)) {
        throw new Error(
          `Duplicate blog folder index for "${folderSlug}". Keep only one folder entry with folder: true.`,
        );
      }
      folderMetaBySlug.set(folderSlug, entry);
    }
  }
});

const posts = entries.filter(isBlogPostEntry);
const datedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// top-level folders and top-level posts
const folderSet = new Set<string>();
const topLevelPosts: BlogPostEntry[] = [];

datedPosts.forEach((p) => {
  const parts = p.slug.split("/");
  if (parts.length > 1) {
    folderSet.add(parts[0]);
  } else {
    topLevelPosts.push(p);
  }
});

const folders = Array.from(folderSet).sort();

type Acc = {
  [year: string]: BlogPostEntry[];
};

const postsByYear = topLevelPosts.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort(
  (a, b) => parseInt(b) - parseInt(a),
);
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="space-y-8">
      <div class="animate font-semibold text-black dark:text-white">Blog</div>

      {
        folders.length > 0 && (
          <section>
            <div class="text-sm font-semibold">Folders</div>
            <div class="mt-3 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
              {folders.map((f) => {
                const meta = folderMetaBySlug.get(f);
                return (
                  <BlogFolderCard
                    name={meta?.data.title ?? f}
                    description={meta?.data.description}
                    href={`/blog/${f}`}
                  />
                );
              })}
            </div>
          </section>
        )
      }

      {
        years.map((year) => (
          <section class="animate space-y-4">
            <div class="font-semibold text-black dark:text-white">{year}</div>
            <div>
              <ul class="flex flex-col gap-4">
                {postsByYear[year].map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))
      }
    </div>
  </Container>
</PageLayout>
